.env
.env.*
!.env.example        # only the example template is safe to commit
.doppler/

# ─── Testing ─────────────────────────────────────────────────
coverage/
.vitest-cache/

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo

# ─── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS & Editor ─────────────────────────────────────────────
