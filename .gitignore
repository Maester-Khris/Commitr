# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build Output ────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Vite ────────────────────────────────────────────────────
*.local
vite.config.ts.timestamp-*

# ─── Environment & Secrets ───────────────────────────────────
